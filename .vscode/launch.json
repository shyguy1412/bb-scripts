{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Deno",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "deno",
      "runtimeArgs": [
        "run",
        "--inspect-brk=127.0.0.1:3333",
        "-A",
        "build.ts"
      ],
      "attachSimplePort": 3333
    },
    {
      "type": "chrome",
      "request": "attach",
      "name": "Attach to BitBurner (Steam)",
      "port": 9222,
    },
    {
      "type": "chrome",
      "request": "attach",
      "name": "Attach to BitBurner (Web)",
      "port": 9222,
      "urlFilter": "https://bitburner-official.github.io/*",
      "webRoot": "${workspaceFolder}"
    }
  ]
}